---
const siteUrl = "https://lacabinepodcasts.com";
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Page introuvable | La Cabine Podcasts</title>
  <meta name="robots" content="noindex, follow" />
  <link rel="canonical" href={siteUrl} />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎙️</text></svg>" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" /></noscript>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img src="/logo.png" alt="La Cabine Podcasts" width="220" height="66" />
    </a>
    <a href="https://wa.me/262692450573" class="btn btn-white nav-cta" target="_blank" rel="noopener">Réserver</a>
  </div>
</nav>

<!-- 404 -->
<main class="page-404">
  <div class="error-layout">
    <img src="/images/404-micro.webp" alt="Micro vintage – page introuvable" class="micro-img micro-left" />
    <div class="error-content">
      <p class="error-num">404</p>
      <h1>Page introuvable.</h1>
      <p class="error-sub">Cette page n'existe pas ou a été déplacée.<br />Pas de panique, le studio est toujours là.</p>
      <div class="error-btns">
        <a href="/" class="btn btn-blue">Retour à l'accueil</a>
        <a href="/#realisations" class="btn btn-outline-blue">Voir nos réalisations</a>
      </div>
    </div>
    <img src="/images/404-micro.webp" alt="" class="micro-img micro-right" aria-hidden="true" />
  </div>
</main>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #ffffff;
    color: #174A96;
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  h1 {
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 800;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    line-height: 1.2;
    color: #174A96;
  }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; height: auto; display: block; }

  /* NAV */
  .nav {
    background: #174A96;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo img { height: 56px; width: auto; }

  /* BUTTONS */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.75rem;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    cursor: pointer;
    transition: transform 0.15s, opacity 0.15s;
    white-space: nowrap;
  }
  .btn:hover { transform: translateY(-2px); opacity: 0.88; }
  .btn-white { background: #ffffff; color: #174A96; }
  .btn-blue { background: #174A96; color: #ffffff; }
  .btn-outline-blue {
    background: transparent;
    color: #174A96;
    border: 2px solid #174A96;
  }

  /* 404 LAYOUT */
  .page-404 {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
  }

  .error-layout {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    max-width: 1100px;
    width: 100%;
  }

  .micro-img {
    width: clamp(160px, 18vw, 260px);
    flex-shrink: 0;
    opacity: 0.9;
  }
  .micro-right {
    transform: scaleX(-1);
  }

  .error-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .error-num {
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 800;
    font-size: clamp(7rem, 18vw, 14rem);
    line-height: 1;
    color: #174A96;
    letter-spacing: -0.04em;
  }

  .error-sub {
    font-size: 1.05rem;
    color: rgba(23, 74, 150, 0.65);
    line-height: 1.6;
    max-width: 380px;
  }

  .error-btns {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  @media (max-width: 768px) {
    .micro-left, .micro-right { display: none; }
    .error-num { font-size: clamp(6rem, 28vw, 10rem); }
  }
</style>
