  /* TYPEWRITER H1 */
  .hero-h1 { text-transform: none; }
  .h1-typewriter { white-space: normal; }
  .typewriter-cursor {
    display: inline-block;
    width: 3px;
    background: currentColor;
    margin-left: 2px;
    vertical-align: baseline;
    animation: blink 0.75s step-end infinite;
    font-weight: 800;
    line-height: 1;
    font-size: 0.9em;
  }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  /* À LA UNE */
  .alaune { padding: 5rem 0 4rem; }
  .alaune h2 { margin-bottom: 2rem; }
  .alaune-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
