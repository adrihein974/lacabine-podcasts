</style>

<script>
  const widget   = document.getElementById('video-widget');
  const closeBtn = document.getElementById('video-widget-close');
  const preview  = document.getElementById('video-preview');
  const lightbox = document.getElementById('video-lightbox');
  const backdrop = document.getElementById('video-backdrop');
  const lbClose  = document.getElementById('lightbox-close');
  const iframe   = document.getElementById('cabine-iframe');

  function openLightbox() {
    iframe.src = iframe.dataset.src;
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    iframe.src = '';
    lightbox.hidden = true;
    document.body.style.overflow = '';
  }

  preview.addEventListener('click', openLightbox);
  preview.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') openLightbox(); });
  backdrop.addEventListener('click', closeLightbox);
  lbClose.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
  closeBtn.addEventListener('click', (e) => { e.stopPropagation(); widget.style.display = 'none'; });
</script>

