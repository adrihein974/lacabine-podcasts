<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #174A96;
    color: #ffffff;
    font-family: 'DM Sans', sans-serif;
    line-height: 1.7;
    overflow-x: hidden;
  }

  h1, h2, h3, h4 { font-family: 'Hanken Grotesk', sans-serif; font-weight: 800; }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

  a { color: inherit; text-decoration: none; }

  /* BARRE DE PROGRESSION */
  #reading-progress {
    position: fixed;
    top: 0; left: 0;
    width: 100%;
    height: 3px;
    background: #ffffff;
    z-index: 9999;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.1s linear;
    border-radius: 0 2px 2px 0;
  }

  /* NAV */
  .nav {
    position: sticky; top: 0; z-index: 100;
    background: #174A96;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding: 0 1.5rem;
  }
  .nav-inner {
    max-width: 1200px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
    height: 70px; gap: 2rem;
  }
  .nav-logo { flex-shrink: 0; }
  .nav-logo img { display: block; width: 220px; height: auto; }
  .nav-links { display: flex; list-style: none; gap: 1.75rem; }
  .nav-links a { font-size: 0.95rem; font-weight: 500; opacity: 0.85; transition: opacity 0.2s; }
  .nav-links a:hover { opacity: 1; }

  .btn { display: inline-block; padding: 0.6rem 1.5rem; border-radius: 50px; font-weight: 700; font-size: 0.9rem; cursor: pointer; transition: all 0.2s; }
  .btn-white { background: #ffffff; color: #174A96; }
  .btn-white:hover { background: #e8f0fe; }
  .btn-outline { background: transparent; color: #ffffff; border: 2px solid rgba(255,255,255,0.5); }
  .btn-outline:hover { border-color: #ffffff; }
  .nav-cta { margin-left: auto; flex-shrink: 0; }

  /* BREADCRUMB */
  .breadcrumb { padding: 1rem 0; border-bottom: 1px solid rgba(255,255,255,0.1); }
  .breadcrumb .container { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
  .breadcrumb a { font-size: 0.82rem; opacity: 0.55; transition: opacity 0.2s; }
  .breadcrumb a:hover { opacity: 1; }
  .breadcrumb span { font-size: 0.82rem; opacity: 0.35; }
  .breadcrumb span:last-child { opacity: 0.7; }

  /* ARTICLE */
  main { padding: 4rem 0 5rem; }
  article { max-width: 780px; margin: 0 auto; }

  .article-header { margin-bottom: 2.5rem; }
  .article-meta { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
  .article-meta time { font-size: 0.85rem; opacity: 0.55; }
  .reading-time { font-size: 0.82rem; opacity: 0.5; }

  .category-badge {
    display: inline-block; padding: 0.25rem 0.8rem;
    border-radius: 50px; font-size: 0.75rem; font-weight: 700;
  }

  .article-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.75rem);
    line-height: 1.2;
    margin-bottom: 1rem;
  }
  .article-intro { font-size: 1.1rem; opacity: 0.7; line-height: 1.65; margin-bottom: 1.25rem; }
  .article-byline { font-size: 0.85rem; opacity: 0.5; }

  .article-cover {
    border-radius: 16px; overflow: hidden;
    margin-bottom: 3rem; aspect-ratio: 16/9;
  }
  .article-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* CONTENU MARKDOWN */
  .article-content { font-size: 1.05rem; line-height: 1.8; }

  .article-content h2 {
    font-size: 1.6rem; margin: 2.5rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }
  .article-content h3 { font-size: 1.2rem; margin: 2rem 0 0.75rem; }
  .article-content p { margin-bottom: 1.25rem; }
  .article-content ul, .article-content ol {
    margin: 1rem 0 1.5rem 1.5rem;
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .article-content li { opacity: 0.85; }
  .article-content strong { color: #ffffff; font-weight: 700; }
  .article-content a { color: #a8c4ff; text-decoration: underline; }
  .article-content a:hover { color: #ffffff; }
  .article-content blockquote {
    border-left: 3px solid rgba(255,255,255,0.3);
    padding-left: 1.5rem; margin: 1.5rem 0;
    opacity: 0.75; font-style: italic;
  }

  /* CTA BANDEAU */
  .article-cta {
    background: rgba(255,255,255,0.08);
    border-top: 1px solid rgba(255,255,255,0.1);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding: 4rem 0;
    text-align: center;
  }
  .cta-label {
    font-size: 0.8rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; opacity: 0.5; margin-bottom: 0.75rem;
  }
  .article-cta h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); margin-bottom: 1rem; }
  .article-cta p { opacity: 0.7; max-width: 520px; margin: 0 auto 2rem; }
  .cta-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  /* FOOTER */
  .footer { background: rgba(0,0,0,0.25); padding: 4rem 0 2rem; }
  .footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; margin-bottom: 3rem; }
  .footer-legal h4 { font-size: 0.8rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.45; margin-bottom: 1rem; }
  .footer-legal ul { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
  .footer-legal a { font-size: 0.9rem; opacity: 0.65; transition: opacity 0.2s; }
  .footer-legal a:hover { opacity: 1; }
  .footer-brand { display: flex; flex-direction: column; gap: 0.75rem; }
  .footer-brand p, .footer-brand address, .footer-brand a { font-size: 0.9rem; opacity: 0.65; font-style: normal; }
  .footer-brand a:hover { opacity: 1; }
  .footer-nav h4, .footer-social h4 { font-size: 0.8rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.45; margin-bottom: 1rem; }
  .footer-nav ul { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
  .footer-nav a { font-size: 0.9rem; opacity: 0.65; transition: opacity 0.2s; }
  .footer-nav a:hover { opacity: 1; }
  .social-links { display: flex; gap: 1rem; }
  .social-links a { opacity: 0.55; transition: opacity 0.2s; }
  .social-links a:hover { opacity: 1; }
  .footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 2rem; }
  .footer-bottom p { font-size: 0.85rem; opacity: 0.4; }
  .footer-bottom a { text-decoration: underline; }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .nav-links { display: none; }
    article { max-width: 100%; }
    .footer-top { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>

<script>
  document.getElementById('footerYear').textContent = new Date().getFullYear().toString();

  // Barre de progression de lecture
  const bar = document.getElementById('reading-progress');
  const article = document.getElementById('article-body');

  function updateProgress() {
    const articleTop = article.offsetTop;
    const articleHeight = article.offsetHeight;
    const scrolled = window.scrollY - articleTop;
    const total = articleHeight - window.innerHeight;
    const pct = total > 0 ? Math.min(1, Math.max(0, scrolled / total)) : 0;
    bar.style.transform = `scaleX(${pct})`;
    bar.setAttribute('aria-valuenow', Math.round(pct * 100).toString());
  }

  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();
</script>

</body>
</html>
