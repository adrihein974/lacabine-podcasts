---
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const featured = allPosts[0];
const rest = allPosts.slice(1);

const siteUrl = 'https://lacabinepodcasts.com';
const title = 'Blog & Ressources | La Cabine Podcasts';
const description = 'Conseils, guides et actualités sur le podcast professionnel, le studio d\'enregistrement et la vidéo à La Réunion. Ressources pour créateurs, entreprises et institutions.';

function formatDate(date: Date) {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}

function readingTime(body: string) {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}

const categoryColors: Record<string, string> = {
  'Actualités': '#E8F4FD',
  'Portraits': '#FEF3E2',
  'Conseils': '#E8F8F0',
  'Outils': '#F3E8FF',
  'Événements': '#FDE8E8',
};
const categoryText: Record<string, string> = {
  'Actualités': '#1565C0',
  'Portraits': '#E65100',
  'Conseils': '#1B5E20',
  'Outils': '#4A148C',
  'Événements': '#B71C1C',
};
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="La Cabine Podcasts" />
  <meta name="publisher" content="La Cabine Podcasts" />
  <meta name="keywords" content="blog podcast, studio podcast La Réunion, conseils podcast, enregistrer un podcast, studio vidéo 974, podcast professionnel Réunion" />
  <link rel="canonical" href={`${siteUrl}/blog`} />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={`${siteUrl}/blog`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}/images/La%20Cabine%20Podcast%20--%20Studio%20Podcasts%20La%20R%C3%A9union%201200%20x%20630.png`} />
  <meta property="og:locale" content="fr_FR" />
  <meta name="twitter:card" content="summary_large_image" />

  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    "@id": "https://lacabinepodcasts.com/blog",
    "name": "Blog & Ressources — La Cabine Podcasts",
    "description": "Conseils, guides et actualités sur le podcast professionnel à La Réunion.",
    "url": "https://lacabinepodcasts.com/blog",
    "publisher": {
      "@type": "Organization",
      "name": "La Cabine Podcasts",
      "url": "https://lacabinepodcasts.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://lacabinepodcasts.com/logo.png"
      }
    },
    "inLanguage": "fr-FR"
  }
  </script>
</head>
<body>

<!-- NAV -->
<nav class="nav" id="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img src="/logo.png" alt="La Cabine Podcasts – Studio podcast La Réunion" width="180" height="54" />
    </a>
    <button class="nav-burger" id="navBurger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links" id="navLinks">
      <li><a href="/#services">Services</a></li>
      <li><a href="/#studio">Studio</a></li>
      <li><a href="/#realisations">Réalisations</a></li>
      <li><a href="/regarder">Regarder</a></li>
      <li><a href="/#faq">FAQ</a></li>
    </ul>
    <a href="https://wa.me/262692450573" class="btn btn-white nav-cta" target="_blank" rel="noopener">Réserver</a>
  </div>
</nav>

<!-- HERO BLOG -->
<section class="blog-hero">
  <div class="container">
    <p class="blog-label">Ressources & conseils</p>
    <h1>Blog & Ressources</h1>
    <p class="blog-subtitle">Guides pratiques, conseils et actualités sur le podcast professionnel à La Réunion.</p>
  </div>
</section>

<!-- ARTICLE EN VEDETTE -->
{featured && (
  <section class="featured-section">
    <div class="container">
      <a href={`/blog/${featured.slug}`} class="featured-card">
        <div class="featured-image">
          <img src={featured.data.image} alt={featured.data.imageAlt} loading="eager" />
        </div>
        <div class="featured-content">
          <div class="featured-meta">
            <span class="category-badge" style={`background:${categoryColors[featured.data.category]};color:${categoryText[featured.data.category]}`}>
              {featured.data.category}
            </span>
            <time datetime={featured.data.date.toISOString().split('T')[0]}>
              {formatDate(featured.data.date)}
            </time>
          </div>
          <h2 class="featured-title">{featured.data.title}</h2>
          <p class="featured-desc">{featured.data.description}</p>
          <div class="featured-footer">
            <span class="reading-time">⏱ {readingTime(featured.body)} min de lecture</span>
            <span class="read-link">Lire l'article →</span>
          </div>
        </div>
      </a>
    </div>
  </section>
)}

<!-- GRILLE ARTICLES -->
{rest.length > 0 && (
  <section class="articles-section">
    <div class="container">
      <h2 class="section-title">Tous les articles</h2>
      <div class="articles-grid">
        {rest.map((post) => (
          <a href={`/blog/${post.slug}`} class="article-card">
            <div class="article-image">
              <img src={post.data.image} alt={post.data.imageAlt} loading="lazy" />
            </div>
            <div class="article-content">
              <div class="article-meta">
                <span class="category-badge" style={`background:${categoryColors[post.data.category]};color:${categoryText[post.data.category]}`}>
                  {post.data.category}
                </span>
                <time datetime={post.data.date.toISOString().split('T')[0]}>
                  {formatDate(post.data.date)}
                </time>
              </div>
              <h3 class="article-title">{post.data.title}</h3>
              <p class="article-desc">{post.data.description}</p>
              <span class="reading-time">⏱ {readingTime(post.body)} min de lecture</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- FOOTER -->
<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <img src="/logo.png" alt="La Cabine Podcasts" width="140" height="42" />
        <p>Studio de création de podcasts à La Réunion</p>
        <address>18 rue Rontaunay, Saint-Denis, La Réunion</address>
        <a href="mailto:lacabinepodcast@gmail.com">lacabinepodcast@gmail.com</a>
      </div>
      <nav class="footer-nav" aria-label="Navigation secondaire">
        <h4>Navigation</h4>
        <ul>
          <li><a href="/#services">Services</a></li>
          <li><a href="/#studio">Studio</a></li>
          <li><a href="/#realisations">Réalisations</a></li>
          <li><a href="/regarder">Regarder</a></li>
          <li><a href="/blog">Blog & Ressources</a></li>
          <li><a href="/#faq">FAQ</a></li>
        </ul>
      </nav>
      <div class="footer-social">
        <h4>Retrouvez-nous</h4>
        <div class="social-links">
          <a href="https://www.instagram.com/lacabinepodcasts" aria-label="Instagram" target="_blank" rel="noopener">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.youtube.com/@LaCabinePodcasts" aria-label="YouTube" target="_blank" rel="noopener">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a href="https://open.spotify.com/show/2P7G6jbg9LFDUCyCmc4aNS" aria-label="Spotify" target="_blank" rel="noopener">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
          </a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© <span id="footerYear"></span> La Cabine Podcasts · Saint-Denis, La Réunion · <a href="mailto:lacabinepodcast@gmail.com">lacabinepodcast@gmail.com</a></p>
    </div>
  </div>
</footer>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #174A96;
    color: #ffffff;
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    line-height: 1.6;
    overflow-x: hidden;
  }

  h1, h2, h3 { font-family: 'Hanken Grotesk', sans-serif; font-weight: 800; }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

  a { color: inherit; text-decoration: none; }

  /* NAV */
  .nav {
    position: sticky; top: 0; z-index: 100;
    background: #174A96;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding: 0 1.5rem;
  }
  .nav-inner {
    max-width: 1200px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
    height: 70px; gap: 2rem;
  }
  .nav-logo { flex-shrink: 0; }
  .nav-logo img { display: block; width: 220px; height: auto; }
  .nav-links { display: flex; list-style: none; gap: 1.75rem; }
  .nav-links a { font-size: 0.95rem; font-weight: 500; opacity: 0.85; transition: opacity 0.2s; }
  .nav-links a:hover { opacity: 1; }
  .nav-burger { display: none; background: none; border: none; cursor: pointer; padding: 4px; flex-direction: column; gap: 5px; }
  .nav-burger span { display: block; width: 24px; height: 2px; background: #fff; border-radius: 2px; }

  .btn { display: inline-block; padding: 0.6rem 1.4rem; border-radius: 50px; font-weight: 700; font-size: 0.9rem; cursor: pointer; transition: all 0.2s; text-decoration: none; }
  .btn-white { background: #ffffff; color: #174A96; }
  .btn-white:hover { background: #e8f0fe; }
  .nav-cta { margin-left: auto; flex-shrink: 0; }

  /* HERO */
  .blog-hero {
    padding: 5rem 0 3rem;
    text-align: center;
  }
  .blog-label {
    font-size: 0.8rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; opacity: 0.6; margin-bottom: 1rem;
  }
  .blog-hero h1 { font-size: clamp(2.5rem, 6vw, 4rem); margin-bottom: 1rem; }
  .blog-subtitle { font-size: 1.1rem; opacity: 0.75; max-width: 560px; margin: 0 auto; }

  /* FEATURED */
  .featured-section { padding: 0 0 4rem; }
  .featured-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    background: rgba(255,255,255,0.06);
    border-radius: 20px;
    overflow: hidden;
    transition: transform 0.25s, box-shadow 0.25s;
    cursor: pointer;
  }
  .featured-card:hover { transform: translateY(-4px); box-shadow: 0 20px 60px rgba(0,0,0,0.3); }

  .featured-image { overflow: hidden; min-height: 380px; }
  .featured-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
  .featured-card:hover .featured-image img { transform: scale(1.03); }

  .featured-content {
    padding: 3rem;
    display: flex; flex-direction: column; justify-content: center; gap: 1.25rem;
  }
  .featured-meta { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .featured-meta time { font-size: 0.85rem; opacity: 0.6; }

  .category-badge {
    display: inline-block;
    padding: 0.25rem 0.8rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .featured-title { font-size: clamp(1.4rem, 2.5vw, 2rem); line-height: 1.25; }
  .featured-desc { opacity: 0.75; line-height: 1.65; }
  .featured-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 0.5rem; }
  .reading-time { font-size: 0.82rem; opacity: 0.55; }
  .read-link { font-weight: 700; font-size: 0.9rem; border-bottom: 2px solid rgba(255,255,255,0.3); padding-bottom: 2px; transition: border-color 0.2s; }
  .featured-card:hover .read-link { border-color: #ffffff; }

  /* GRID */
  .articles-section { padding: 2rem 0 6rem; }
  .section-title { font-size: 1.5rem; margin-bottom: 2.5rem; opacity: 0.9; }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .article-card {
    background: rgba(255,255,255,0.06);
    border-radius: 16px;
    overflow: hidden;
    display: flex; flex-direction: column;
    transition: transform 0.25s, box-shadow 0.25s;
    cursor: pointer;
  }
  .article-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0,0,0,0.25); }

  .article-image { overflow: hidden; height: 200px; }
  .article-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
  .article-card:hover .article-image img { transform: scale(1.04); }

  .article-content { padding: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem; flex: 1; }
  .article-meta { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .article-meta time { font-size: 0.8rem; opacity: 0.55; }
  .article-title { font-size: 1.05rem; line-height: 1.35; }
  .article-desc { font-size: 0.88rem; opacity: 0.65; line-height: 1.6; flex: 1; }

  /* FOOTER */
  .footer { background: rgba(0,0,0,0.25); padding: 4rem 0 2rem; margin-top: 2rem; }
  .footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 3rem; margin-bottom: 3rem; }
  .footer-brand { display: flex; flex-direction: column; gap: 0.75rem; }
  .footer-brand p, .footer-brand address, .footer-brand a { font-size: 0.9rem; opacity: 0.65; font-style: normal; }
  .footer-brand a:hover { opacity: 1; }
  .footer-nav h4, .footer-social h4 { font-size: 0.85rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.5; margin-bottom: 1rem; }
  .footer-nav ul { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
  .footer-nav a { font-size: 0.9rem; opacity: 0.7; transition: opacity 0.2s; }
  .footer-nav a:hover { opacity: 1; }
  .social-links { display: flex; gap: 1rem; flex-wrap: wrap; }
  .social-links a { opacity: 0.6; transition: opacity 0.2s; }
  .social-links a:hover { opacity: 1; }
  .footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 2rem; }
  .footer-bottom p { font-size: 0.85rem; opacity: 0.45; }
  .footer-bottom a { text-decoration: underline; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .featured-card { grid-template-columns: 1fr; }
    .featured-image { min-height: 260px; }
    .articles-grid { grid-template-columns: repeat(2, 1fr); }
    .footer-top { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .nav-links { display: none; }
    .nav-burger { display: flex; }
    .articles-grid { grid-template-columns: 1fr; }
    .featured-content { padding: 2rem 1.5rem; }
    .footer-top { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>

<script>
  document.getElementById('footerYear').textContent = new Date().getFullYear().toString();

  const burger = document.getElementById('navBurger');
  const links = document.getElementById('navLinks');
  burger?.addEventListener('click', () => {
    const open = links?.style.display === 'flex';
    links.style.display = open ? 'none' : 'flex';
  });
</script>

</body>
</html>
